/**
 * Autonomous Campaign Service - GOOGLE-ONLY
 * All asset generation powered by Gemini + Google tools
 * DNA-driven: uses company DNA as system prompt prefix
 */

import { universalAiService } from './universalAiService';
import { imageGenerationService } from './imageGenerationService';
import { videoService } from './videoService';
import { sonicLabService } from './sonicLabService';
import { dnaExtractionService, CompanyDNA } from './dnaExtractionService';
import { firebaseService } from './firebaseService';
import { creditsService } from './creditsService';

export interface CampaignAsset {
  id: string;
  title: string;
  content: string;
  imageUrl?: string;
  videoUrl?: string;
  audioUrl?: string;
  cta: string;
  platform: string; // 'instagram' | 'facebook' | 'twitter' | 'linkedin' | 'email'
  createdAt: string;
}

export interface Campaign {
  id: string;
  dnaId: string;
  name: string;
  theme: string;
  assets: CampaignAsset[];
  createdAt: string;
}

class AutonomousCampaignService {
  
  async generateFullCampaign(
    userId: string,
    dnaId: string,
    campaignTheme: string,
    platforms: string[] = ['instagram', 'facebook', 'linkedin']
  ): Promise<Campaign> {
    console.log(`🚀 Generating full campaign: ${campaignTheme}`);

    // Check if user can claim free campaign
    const isFree = await creditsService.canClaimFirstCampaignFree(userId);
    
    if (!isFree) {
      // Check credits for paid campaign
      const canAfford = await creditsService.canAffordOperation('campaign-full');
      if (!canAfford) {
        throw new Error('❌ Insufficient credits for campaign generation (requires 100 credits)');
      }
    }

    // Get DNA profile
    const dna = await firebaseService.getDNAProfile(userId, dnaId);
    if (!dna) {
      throw new Error('❌ DNA profile not found');
    }

    const campaignId = `campaign_${Date.now()}`;
    const assets: CampaignAsset[] = [];

    // Generate assets for each platform
    for (const platform of platforms) {
      console.log(`📱 Generating ${platform} asset...`);
      const asset = await this.generateAssetForPlatform(dna, campaignTheme, platform);
      assets.push(asset);
    }

    // Deduct credits (or mark as free campaign)
    if (isFree) {
      await creditsService.grantFirstCampaignFree();
      console.log(`✨ First campaign FREE for user`);
    } else {
      await creditsService.deductOperationCredits('campaign-full');
    }

    // Save campaign to Firebase
    const campaign: Campaign = {
      id: campaignId,
      dnaId,
      name: campaignTheme,
      theme: campaignTheme,
      assets,
      createdAt: new Date().toISOString()
    };

    await firebaseService.saveCampaign(userId, campaignId, campaign);

    console.log(`✅ Campaign complete: ${campaignId} with ${assets.length} assets`);
    return campaign;
  }

  private async generateAssetForPlatform(dna: CompanyDNA, campaignTheme: string, platform: string): Promise<CampaignAsset> {
    const systemPrompt = dnaExtractionService.getSystemPromptFromDNA(dna);

    // 1. Generate copy
    const copyPrompt = `Create a compelling ${platform} post for campaign: "${campaignTheme}"

Platform requirements:
${this.getPlatformRequirements(platform)}

Return JSON with ONLY these fields:
{
  "title": "Post title or headline",
  "content": "Main post text",
  "cta": "Call to action button text",
  "hashtags": ["hashtag1", "hashtag2", "hashtag3"],
  "imageDescription": "Vivid description for image generation"
}`;

    const copyResponse = await universalAiService.generateText({
      prompt: copyPrompt,
      systemInstruction: systemPrompt,
      responseMimeType: 'application/json',
      featureId: 'campaign-asset-copy'
    });

    const copyData = JSON.parse(copyResponse);

    // 2. Generate image
    console.log(`🎨 Generating image for ${platform}...`);
    const image = await imageGenerationService.generateBrandedImage(
      dna,
      copyData.imageDescription,
      'illustrated'
    );

    // 3. Generate optional video (for certain platforms)
    let videoUrl: string | undefined;
    if (['instagram', 'facebook', 'tiktok'].includes(platform)) {
      console.log(`🎬 Generating video for ${platform}...`);
      try {
        const video = await videoService.generateSocialMediaVideo(
          dna,
          platform as 'tiktok' | 'instagram' | 'youtube',
          copyData.content,
          15
        );
        videoUrl = video.url;
      } catch (e) {
        console.warn(`⚠️ Video generation skipped: ${e}`);
      }
    }

    // 4. Generate optional audio (for video platforms)
    let audioUrl: string | undefined;
    if (['instagram', 'tiktok'].includes(platform) && videoUrl) {
      console.log(`🎵 Generating audio for ${platform}...`);
      try {
        const audio = await sonicLabService.generateVoiceOver(dna, copyData.content);
        audioUrl = audio.audioUrl;
      } catch (e) {
        console.warn(`⚠️ Audio generation skipped: ${e}`);
      }
    }

    const asset: CampaignAsset = {
      id: `asset_${Date.now()}`,
      title: copyData.title,
      content: copyData.content,
      imageUrl: image.url,
      videoUrl,
      audioUrl,
      cta: copyData.cta,
      platform,
      createdAt: new Date().toISOString()
    };

    return asset;
  }

  private getPlatformRequirements(platform: string): string {
    const reqs: Record<string, string> = {
      instagram: 'Max 2,200 characters. Emojis encouraged. 3-5 hashtags. Visual-first.',
      facebook: 'Max 63,206 characters. Conversational tone. Use line breaks. 5-10 hashtags.',
      linkedin: 'Professional tone. Thought leadership. Max 3,000 characters. 3-5 hashtags.',
      twitter: 'Max 280 characters. Punchy. Trending relevant. 1-2 hashtags.',
      tiktok: 'Trendy, Gen-Z voice. Max 150 characters. Hook in first 3 seconds.',
      email: 'Subject line (60 chars). Body (150-200 words). Clear CTA.'
    };
    return reqs[platform] || 'Standard social media post guidelines.';
  }

  async regenerateAsset(
    userId: string,
    campaignId: string,
    assetIndex: number,
    regenerateImage: boolean = true,
    regenerateVideo: boolean = true
  ): Promise<CampaignAsset> {
    // Get campaign
    const campaign = await firebaseService.getCampaign(userId, campaignId);
    const asset = campaign.assets[assetIndex];

    if (!asset) {
      throw new Error('Asset not found');
    }

    // Get DNA
    const dna = await firebaseService.getDNAProfile(userId, campaign.dnaId);

    // Regenerate specific components
    if (regenerateImage && asset.imageUrl) {
      const image = await imageGenerationService.generate({
        prompt: asset.title || 'Refresh campaign image'
      });
      asset.imageUrl = image.url;
    }

    if (regenerateVideo && asset.videoUrl) {
      const video = await videoService.generateSocialMediaVideo(
        dna,
        asset.platform as 'instagram' | 'tiktok' | 'youtube',
        asset.content,
        15
      );
      asset.videoUrl = video.url;
    }

    // Update in Firebase
    await firebaseService.saveCampaign(userId, campaignId, campaign);

    console.log(`✅ Asset regenerated: ${asset.id}`);
    return asset;
  }
}

export const autonomousCampaignService = new AutonomousCampaignService();
