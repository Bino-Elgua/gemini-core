# Sacred Core - Google-Only Stack
# Configure only these environment variables

# ===== GOOGLE (REQUIRED) =====
VITE_GEMINI_API_KEY=your_google_api_key_here
VITE_GOOGLE_PROJECT_ID=your_google_project_id
VITE_GOOGLE_REGION=us-central1

# ===== FIREBASE (REQUIRED) =====
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_URL=https://your_project.firebaseio.com

# ===== VITE =====
VITE_API_URL=http://localhost:4000
VITE_APP_URL=http://localhost:3001

# ===== SERVER =====
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# ===== REMOVED (NOT NEEDED) =====
# - VITE_OPENAI_API_KEY ❌ (Gemini only)
# - VITE_ANTHROPIC_API_KEY ❌ (Gemini only)
# - VITE_GROQ_API_KEY ❌ (Gemini only)
# - VITE_MISTRAL_API_KEY ❌ (Gemini only)
# - VITE_STABILITY_API_KEY ❌ (Imagen 3 only)
# - VITE_FAL_API_KEY ❌ (Veo 3 only)
# - VITE_LUMA_API_KEY ❌ (Veo 3 only)
# - HUNTER_API_KEY ❌ (Gemini synthesis only)
# - APOLLO_API_KEY ❌ (Gemini synthesis only)
# - VITE_SUPABASE_URL ❌ (Firebase replaces it)
# - VITE_SUPABASE_ANON_KEY ❌ (Firebase replaces it)
# - All other providers ❌ Removed entirely
